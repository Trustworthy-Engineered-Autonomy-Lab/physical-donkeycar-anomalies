#!/bin/bash
#SBATCH --job-name=donkey-baseline-gpu
#SBATCH --output=logs/donkey-baseline-gpu-%j.out
#SBATCH --error=logs/donkey-baseline-gpu-%j.err
#SBATCH --partition=hwgui
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --gpus=1
#SBATCH --mem=16gb
#SBATCH --time=10:00:00

set -euo pipefail

PROJECT_DIR="/blue/iruchkin/jaynibhanupudy/physical-donkeycar-anomalies"
CONDA_ENV="/blue/iruchkin/jaynibhanupudy/.conda/envs/anomalies"
MODEL_PATH="${MODEL_PATH:-models/mini_monaco.h5}"
TRIALS="${TRIALS:-40}"
START_DELAY="${START_DELAY:-15.0}"
UNITY_FLAGS="${UNITY_FLAGS:--force-glcore}"
GPU_MONITOR_INTERVAL="${GPU_MONITOR_INTERVAL:-2}"
DISPLAY_NUM="$((90 + (${SLURM_JOB_ID:-0} % 100)))"

cd "${PROJECT_DIR}"
mkdir -p logs trials

module load conda
source "$(conda info --base)/etc/profile.d/conda.sh"
conda activate "${CONDA_ENV}"

export PYTHONNOUSERSITE=1
export PYTHONPATH="${PROJECT_DIR}/donkeycar${PYTHONPATH:+:${PYTHONPATH}}"
export MPLBACKEND=Agg
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export VGL_VERBOSE=1
export DISPLAY=":${DISPLAY_NUM}"
unset LIBGL_ALWAYS_SOFTWARE

Xvfb "${DISPLAY}" -screen 0 1280x720x24 -nolisten tcp &
XVFB_PID=$!

RUNTIME_MYCONFIG="myconfig_baseline_gpu_${SLURM_JOB_ID:-manual}.py"
SIM_WRAPPER="logs/donkey_sim_baseline_gpu_${SLURM_JOB_ID:-manual}.sh"
GPU_MONITOR_LOG="logs/donkey-baseline-gpu-nvidia-smi-${SLURM_JOB_ID:-manual}.log"

cat > "${SIM_WRAPPER}" <<EOF
#!/bin/bash
exec vglrun -d egl "${PROJECT_DIR}/donkey-unity-sim/donkey_sim.x86_64" ${UNITY_FLAGS} "\$@"
EOF
chmod +x "${SIM_WRAPPER}"

cp myconfig.py "${RUNTIME_MYCONFIG}"
cat >> "${RUNTIME_MYCONFIG}" <<EOF

# Runtime overrides generated by run_baseline_trials_gpu.sbatch.
DONKEY_SIM_PATH = r"${PROJECT_DIR}/${SIM_WRAPPER}"
GYM_CONF["start_delay"] = ${START_DELAY}
EOF
if [[ -n "${MAX_LOOPS_OVERRIDE:-}" ]]; then
    cat >> "${RUNTIME_MYCONFIG}" <<EOF
MAX_LOOPS = ${MAX_LOOPS_OVERRIDE}
EOF
fi

cleanup() {
    if [[ -n "${GPU_MONITOR_PID:-}" ]]; then
        kill "${GPU_MONITOR_PID}" 2>/dev/null || true
    fi
    rm -f "${RUNTIME_MYCONFIG}" "${SIM_WRAPPER}"
    kill "${XVFB_PID}" 2>/dev/null || true
}
trap cleanup EXIT

echo "HOSTNAME=$(hostname)"
echo "DISPLAY=${DISPLAY}"
echo "MODEL_PATH=${MODEL_PATH}"
echo "TRIALS=${TRIALS}"
echo "START_DELAY=${START_DELAY}"
echo "UNITY_FLAGS=${UNITY_FLAGS}"
echo "MAX_LOOPS_OVERRIDE=${MAX_LOOPS_OVERRIDE:-unset}"
echo "ANOMALY_MODE=none"
echo "GPU_MONITOR_LOG=${GPU_MONITOR_LOG}"
nvidia-smi || true

sleep 2

if command -v nvidia-smi >/dev/null 2>&1; then
    {
        while true; do
            date
            nvidia-smi
            sleep "${GPU_MONITOR_INTERVAL}"
        done
    } >> "${GPU_MONITOR_LOG}" 2>&1 &
    GPU_MONITOR_PID=$!
else
    echo "WARNING: nvidia-smi not found; cannot monitor GPU process usage." >&2
fi

# Intentionally pass no --meta arguments: this is the no-anomaly baseline.
python_status=0
RACE=True python3.11 trials.py run_trials \
    --myconfig="${RUNTIME_MYCONFIG}" \
    --model="${MODEL_PATH}" \
    --trials="${TRIALS}" || python_status=$?

if [[ -n "${GPU_MONITOR_PID:-}" ]]; then
    kill "${GPU_MONITOR_PID}" 2>/dev/null || true
    unset GPU_MONITOR_PID
fi

if [[ -f "${GPU_MONITOR_LOG}" ]]; then
    if grep -q "donkey_sim.x86_64" "${GPU_MONITOR_LOG}"; then
        echo "GPU verification: donkey_sim.x86_64 appeared in nvidia-smi while trials were running."
    else
        echo "WARNING: donkey_sim.x86_64 was not found in ${GPU_MONITOR_LOG}." >&2
        echo "Check stderr for '[VGL] Opening EGL device egl' and inspect the monitor log manually." >&2
    fi
fi

exit "${python_status}"
